# ===== Supabase Postgres =====
# Pooled connection (port 6543, pgBouncer) — used by the runtime app
DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection (port 5432) — required by `prisma migrate`
DIRECT_DATABASE_URL="postgresql://postgres.PROJECTREF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ===== Auth =====
# 32-byte random base64. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=""
JWT_TTL="15m"

# ===== Admin bootstrap (only consumed by prisma/seed.ts) =====
ADMIN_SEED_USER="admin"
# bcrypt hash. Generate: node -e "console.log(require('bcryptjs').hashSync('password123', 10))"
ADMIN_SEED_PASSWORD_HASH=""
ADMIN_SEED_NAME="Juan M."
ADMIN_SEED_EMAIL="admin@gstock.local"

# ===== CORS =====
# Comma-separated list of exact origins. Vercel preview pattern is also auto-allowed at code level.
CORS_ORIGIN="https://gstock.vercel.app,https://gstock-pu8zsienk-giampiers-projects.vercel.app,http://localhost:3000"

# ===== Swagger basic auth (only enforced when NODE_ENV=production AND both set) =====
SWAGGER_USER=""
SWAGGER_PASSWORD=""

# ===== Runtime =====
NODE_ENV="development"
PORT="3001"
LOG_LEVEL="debug"
