generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum Role {
  ADMIN
}

enum MovementType {
  IN
  OUT
}

enum ProductStatus {
  ACTIVE
  LOW_STOCK
  INACTIVE
}

model User {
  id                 String   @id @default(cuid())
  username           String   @unique
  email              String   @unique
  name               String
  passwordHash       String
  role               Role     @default(ADMIN)
  emailNotifications Boolean  @default(true)
  darkMode           Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  movements Movement[] @relation("MovementUser")

  @@map("users")
}

model Provider {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  phone     String?
  email     String?
  address   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("providers")
}

model Product {
  id          String        @id @default(cuid())
  sku         String        @unique
  name        String
  description String?
  category    String
  price       Decimal       @db.Decimal(12, 2)
  cost        Decimal       @db.Decimal(12, 2)
  stock       Int           @default(0)
  minStock    Int           @default(0)
  status      ProductStatus @default(ACTIVE)
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  providerId String?
  provider   Provider? @relation(fields: [providerId], references: [id], onDelete: SetNull)

  movements Movement[]

  @@index([category])
  @@index([status])
  @@map("products")
}

model Movement {
  id        String       @id @default(cuid())
  type      MovementType
  quantity  Int
  reason    String?
  createdAt DateTime     @default(now())

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation("MovementUser", fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([createdAt])
  @@map("movements")
}
