{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "prisma generate && nest build",
  "installCommand": "npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/health", "destination": "/api" },
    { "source": "/docs", "destination": "/api" },
    { "source": "/docs-json", "destination": "/api" },
    { "source": "/v1/:path*", "destination": "/api" }
  ]
}
